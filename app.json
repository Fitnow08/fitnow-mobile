{
	"expo": {
		"name": "fitnow-mobile",
		"slug": "fitnow-mobile",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "fitnowmobile",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],

			[
				"expo-font",
				{
					"fonts": [
						"./assets/fonts/manrope/Manrope-Bold.otf",
						"./assets/fonts/manrope/Manrope-Medium.otf",
						"./assets/fonts/manrope/Manrope-Regular.otf",
						"./assets/fonts/SF_PRO/SFPRO_BOLD.otf",
						"./assets/fonts/SF_PRO/SFPRO_MEDIUM.otf",
						"./assets/fonts/SF_PRO/SFPRO_REGULAR.otf",
						"./assets/fonts/SF_PRO/SFPRO_SEMIBOLDITALIC.otf"
					]
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		}
	}
}
